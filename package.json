{
  "name": "crmforall",
  "version": "1.0.0",
  "description": "CRM application with Node.js backend and MongoDB database",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "build:analytics": "tsc -p tsconfig.analytics.json",
    "check": "tsc --noEmit",
    "db:migrate": "node scripts/migrate-to-mongodb.js",
    "db:init": "node -e \"import('./src/mongodb.js').then(m => m.initializeMongoDBSchema()).catch(console.error)\"",
    "db:backup": "bash scripts/backup-mongodb.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "hono": "^4.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "multer": "^2.1.1",
    "pdfjs-dist": "^5.4.449",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
